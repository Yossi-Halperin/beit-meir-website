# ============================================================
# Beit Meir Website — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# --- Site URL (used for sitemap, OG images) ---
NEXT_PUBLIC_SITE_URL=https://beit-meir.co.il

# --- Resend (email notifications to Yossi) ---
# Sign up at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=leads@beit-meir.co.il
RESEND_TO_EMAIL=yossi@example.com

# --- Airtable (lead storage) ---
# Get API key from https://airtable.com/account
# Create a base called "Beit Meir Leads" with a table called "Leads"
# Fields: Name, Phone, Email, PreferredContact, Interest, Locale, UTMSource, UTMMedium, UTMCampaign, Referrer, UserAgent, CreatedAt
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Leads

# --- CallMeBot (WhatsApp notification to Yossi) ---
# Follow setup at https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=XXXXXXXX
CALLMEBOT_PHONE=972XXXXXXXXX

# --- Mapbox (interactive map) ---
# Get token at https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- WhatsApp click-to-chat ---
# Format: 972XXXXXXXXX (no + sign, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=972XXXXXXXXX

# --- Analytics ---
# Plausible: https://plausible.io (privacy-friendly, no cookie banner needed)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=beit-meir.co.il

# Meta Pixel: https://business.facebook.com (requires cookie consent banner)
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX
